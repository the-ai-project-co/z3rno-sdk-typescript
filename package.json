{
  "name": "@z3rno/sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for Z3rno — AI agent memory database",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc"
  },
  "author": "The AI Project Co. <engineering@z3rno.dev>",
  "homepage": "https://z3rno.dev",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.8.0",
    "tsup": "^8.5.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "keywords": [
    "ai-agents",
    "memory",
    "vector-database",
    "rag",
    "agent-memory",
    "pgvector",
    "deno",
    "bun"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-ai-project-co/z3rno-sdk-typescript"
  }
}
